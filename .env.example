# URL completa da sua instância Evolution API no Railway
# Exemplo: https://evolution-api-production-xxxx.up.railway.app
EVOLUTION_URL=https://SUA-EVOLUTION-API.up.railway.app

# Chave global da Evolution API (definida em AUTHENTICATION_API_KEY no deploy da Evolution)
EVOLUTION_KEY=sua-chave-aqui

# Nome da instância criada na Evolution API
EVOLUTION_INSTANCE=voos

# (Opcional) Seu número de WhatsApp no formato internacional sem + nem espaços
# Se preenchido, o bot responde SOMENTE a esse número
# Exemplo: 5521999990000
NUMERO_AUTORIZADO=

# Porta local (Railway define automaticamente via $PORT)
PORT=5000
